{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Cazzmachine",
  "version": "0.2.3",
  "identifier": "com.cazzmachine.app",
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Cazzmachine",
        "width": 950,
        "height": 920,
        "minWidth": 800,
        "minHeight": 850,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Cazzmachine - Doomscrolling for you"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "android": {
      "minSdkVersion": 24
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
